# Solo necesitas la API key del proveedor que configures en config.json (llm_provider)
GEMINI_API_KEY=your_google_ai_studio_api_key_here
DEEPSEEK_API_KEY=your_deepseek_api_key_here
# LOCAL_API_KEY es opcional - la mayoria de servidores locales (Ollama, LM Studio, etc.) no la requieren
LOCAL_API_KEY=

GHIDRA_PATH=/path/to/ghidra/support/analyzeHeadless
